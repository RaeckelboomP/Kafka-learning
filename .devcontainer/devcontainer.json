{
  "name": "Java Devcontainer",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "pivotal.vscode-spring-boot",
        "redhat.vscode-xml"
      ]
    }
  },
  "forwardPorts": [8080],
  "postCreateCommand": "mvn -q -DskipTests package || true"
}
